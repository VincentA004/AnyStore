# Frontend-facing managed API base URL
NEXT_PUBLIC_ANYSTORE_API_URL=https://<managed-api-host>/api

# Managed proxy -> agentic backend
AGENTIC_BACKEND_URL=https://<agent-service-host>
AGENT_PROXY_SHARED_SECRET=<shared-secret-for-service-to-service-calls>

# Google ADK / GCP agentic backend
GOOGLE_CLOUD_PROJECT=<gcp-project-id>
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_APPLICATION_CREDENTIALS=/path/to/local-service-account.json
ANYSTORE_AGENT_MODEL=gemini-2.5-pro
ANYSTORE_STORAGE_BUCKET=<documents-bucket>
ANYSTORE_FIRESTORE_DATABASE=(default)
