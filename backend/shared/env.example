# Frontend-facing managed API base URL
NEXT_PUBLIC_ANYSTORE_API_URL=https://<function-app>.azurewebsites.net/api

# Azure Function proxy
AGENTIC_BACKEND_URL=https://<agent-service-host>
AGENT_PROXY_SHARED_SECRET=<shared-secret-for-service-to-service-calls>

# Agentic backend / Azure AI Foundry
AZURE_AI_FOUNDRY_ENDPOINT=https://<foundry-resource>.services.ai.azure.com
AZURE_AI_FOUNDRY_PROJECT=<project-name>
AZURE_AI_FOUNDRY_AGENT_ID=<agent-id>
AZURE_CLIENT_ID=<managed-identity-or-app-client-id>
AZURE_TENANT_ID=<tenant-id>
